<!DOCTYPE html>
<html
  lang="en"
  xmlns="http://www.w3.org/1999/xhtml"
  xmlns:o="urn:schemas-microsoft-com:office:office"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Account Verified</title>
    <style>
      body {
        margin: 0;
        width: 100% !important;
        -webkit-text-size-adjust: 100%;
        padding: 20px 0;
        font-family: Arial, sans-serif;
        background-color: #f4f4f4;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        padding: 20px;
        border-radius: 8px;
      }
      .header {
        text-align: center;
        padding: 10px 0;
      }
      .header h1 {
        margin: 0;
        color: #273535;
        font-size: 24px;
      }
      .content {
        padding: 20px;
        text-align: center;
        color: #333333;
        line-height: 1.6;
      }
      .button {
        display: block;
        width: 200px;
        margin: 30px auto;
        padding: 15px 20px;
        background-color: #5c6d76;
        color: #ffffff;
        text-align: center;
        text-decoration: none;
        border-radius: 5px;
      }
      .footer {
        text-align: center;
        font-size: 12px;
        color: #777777;
        padding: 20px;
      }
      .footer p {
        margin: 5px 0;
      }

      @media screen and (max-width: 600px) {
        .container {
          width: 100% !important;
          max-width: 100% !important;
          padding: 10px !important;
        }
        .content {
          padding: 10px !important;
        }
        .button {
          width: 100% !important;
          box-sizing: border-box;
          max-width: 250px;
        }
      }
    </style>
  </head>
  <body>
    <table
      width="100%"
      border="0"
      cellspacing="0"
      cellpadding="0"
      style="background-color: #f4f4f4"
    >
      <tr>
        <td align="center">
          <table
            class="container"
            width="600"
            border="0"
            style="border-radius: 8px"
            cellpadding="0"
          >
            <tr>
              <td>
                <div class="header">
                  <h1>Account Verified!</h1>
                </div>
              </td>
            </tr>
            <tr>
              <td>
                <div class="content">
                  <p>Hi <%= name %>,</p>
                  <p>
                    Congratulations! Your account has been successfully
                    verified. You can now log in and explore all the features of
                    Ade's Note.
                  </p>
                  <a href="#" class="button" style="color: #ffffff"
                    >Go to Your Account</a
                  >
                </div>
              </td>
            </tr>
            <tr>
              <td>
                <div class="footer">
                  <p>
                    This is an automated message, please do not reply directly
                    to this email.
                  </p>
                  <p>&copy; 2026 Ade's Note. All rights reserved.</p>
                </div>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
